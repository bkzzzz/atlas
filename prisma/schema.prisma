generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// This model is the first persistent data owned by Atlas.
model Character {
  id          String   @id @default(cuid())
  name        String
  description String
  personality String
  species     String
  createdAt   DateTime @default(now())
}
